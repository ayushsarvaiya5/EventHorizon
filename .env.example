# EventHorizon SOC - Environment Configuration
# Copy this to .env and fill in your values

# Google Gemini API Key (https://ai.google.dev/)
# This enables AI-powered security insights
GEMINI_API_KEY=your_gemini_api_key_here

# Database URL (use SQLite path for local/simple deployment)
# For production, you can use PostgreSQL: postgresql://user:pass@host:port/db
DATABASE_URL=eventhorizon.db

# Server port
PORT=8000

# Deployment environment (local, staging, production)
ENVIRONMENT=development

# Optional: Timezone
TZ=UTC
